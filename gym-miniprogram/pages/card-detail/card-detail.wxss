/* pages/card-detail/card-detail.wxss */

.page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; padding-bottom: 140rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

.scroll { height: calc(100vh - 88rpx); }

/* ============ 顶部大卡 ============ */
.mcard {
  margin: 24rpx 24rpx 0;
  padding: 36rpx 32rpx;
  border-radius: 20rpx;
  color: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(0,0,0,0.12);
}
.mcard--purple { background: linear-gradient(135deg, #6B8AFD, #8E6BFD); }
.mcard--red { background: linear-gradient(135deg, #F77062, #C44569); }
.mcard--teal { background: linear-gradient(135deg, #4FD1C5, #319795); }
.mcard-name { font-size: 40rpx; font-weight: 700; margin-bottom: 12rpx; letter-spacing: 1rpx; }
.mcard-type {
  font-size: 24rpx; background: rgba(255,255,255,0.25);
  padding: 4rpx 16rpx; border-radius: 16rpx;
  display: inline-block; margin-bottom: 24rpx;
}
.mcard-row { font-size: 26rpx; opacity: 0.95; line-height: 1.8; }
.mcard-val { font-weight: 600; }
.mcard-foot {
  display: flex; align-items: baseline;
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.3);
}
.mcard-price { font-size: 26rpx; }
.mcard-price-val { font-size: 36rpx; font-weight: 700; margin: 0 4rpx; }
.mcard-origin {
  font-size: 24rpx; opacity: 0.7;
  text-decoration: line-through; margin-left: 16rpx;
}

/* ============ block ============ */
.block {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx 28rpx 32rpx;
}
.block-title {
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx; position: relative;
}
.block-title::before {
  content: ''; position: absolute; left: 0; top: 8rpx; bottom: 8rpx;
  width: 6rpx; background: #1890FF; border-radius: 3rpx;
}

/* ============ 规格列表 ============ */
.spec-list {}
.spec-row {
  display: flex; align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.spec-row:last-child { border-bottom: none; }
.spec-info { flex: 1; }
.spec-label { font-size: 28rpx; color: #1a1a1a; font-weight: 500; margin-bottom: 8rpx; }
.spec-original { font-size: 22rpx; color: #999999; margin-bottom: 4rpx; }
.spec-days { font-size: 22rpx; color: #888888; }

.spec-radio {
  width: 36rpx; height: 36rpx;
  border: 4rpx solid #cccccc; border-radius: 50%;
  background: #ffffff; flex-shrink: 0;
  box-sizing: border-box; position: relative;
}
.spec-radio--checked { border-color: #1890FF; background: #1890FF; }
.spec-radio--checked::after {
  content: ''; position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx; height: 16rpx; background: #ffffff; border-radius: 50%;
}

/* ============ 销售人员选择器 ============ */
.picker-row {
  display: flex; align-items: center;
  padding: 20rpx 24rpx;
  background: #F8F8FB; border-radius: 8rpx;
}
.picker-text { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.picker-text--placeholder { color: #999999; }
.picker-arrow { font-size: 28rpx; color: #999999; }

/* ============ 协议 + 支付 ============ */
.agree-row {
  display: flex; align-items: center;
  padding: 16rpx 0 24rpx;
}
.agree-check {
  width: 32rpx; height: 32rpx; border: 2rpx solid #cccccc;
  border-radius: 4rpx; margin-right: 12rpx; flex-shrink: 0;
  background: #ffffff; position: relative;
}
.agree-check--checked { background: #1890FF; border-color: #1890FF; }
.agree-check--checked::after {
  content: '✓'; color: #ffffff;
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  font-size: 24rpx; font-weight: 700;
}
.agree-text { font-size: 26rpx; color: #555555; }
.agree-link { font-size: 26rpx; color: #1890FF; }

.pay-row { display: flex; align-items: center; padding: 16rpx 0; border-top: 1rpx solid #f0f0f0; }
.pay-label { font-size: 28rpx; color: #555555; width: 140rpx; }
.pay-option {
  flex: 1; display: flex; align-items: center;
  padding: 20rpx 24rpx; background: #F8F8FB; border-radius: 8rpx;
}
.pay-icon { font-size: 36rpx; margin-right: 12rpx; }
.pay-name { font-size: 28rpx; color: #1a1a1a; }

/* ============ 提交条 ============ */
.submit-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  height: 120rpx; background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex; align-items: center;
  padding: 0 16rpx; z-index: 50;
}
.submit-left { padding: 0 16rpx; flex-shrink: 0; }
.submit-service { font-size: 24rpx; color: #555555; }
.submit-price {
  flex: 0 0 200rpx;
  display: flex; flex-direction: column; align-items: flex-end;
  padding: 0 16rpx;
}
.submit-price-val { font-size: 36rpx; color: #FF4D4F; font-weight: 700; }
.submit-price-label { font-size: 20rpx; color: #999999; }
.submit-btn {
  flex: 1; height: 88rpx; line-height: 88rpx;
  background: #1890FF; color: #ffffff;
  text-align: center; font-size: 32rpx; font-weight: 600;
  border-radius: 44rpx; letter-spacing: 2rpx;
}
.submit-btn--disabled { background: #cccccc; }

.bottom-spacer { height: 60rpx; }

/* ============ 加载 ============ */
.loading-state {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #999999; font-size: 26rpx;
}
.spinner {
  width: 32rpx; height: 32rpx; border: 4rpx solid #e0e0e0;
  border-top-color: #1890FF; border-radius: 50%;
  margin-bottom: 16rpx; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
