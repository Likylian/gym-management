/* pages/venue/venue.wxss */

.venue-page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; }

/* ============ 自定义 navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx;
  background: #3F3358;
  display: flex; align-items: center; justify-content: center;
  z-index: 99;
}
.navbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}
.navbar-actions {
  position: absolute; right: 24rpx; top: 0; bottom: 0;
  display: flex; align-items: center;
}
.navbar-icon {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
}

/* ============ 列表 ============ */
.list { padding: 24rpx; }

.card {
  display: flex; align-items: stretch;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 封面 */
.cover {
  width: 180rpx; height: 180rpx;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.cover-emoji { font-size: 90rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15)); }

/* 中间信息 */
.info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex; flex-direction: column; justify-content: center;
  min-width: 0;
}
.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.addr, .phone {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 6rpx;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* 右侧 */
.right {
  width: 130rpx;
  display: flex; flex-direction: column; align-items: flex-end;
  justify-content: space-between;
  padding: 20rpx 20rpx 20rpx 0;
  flex-shrink: 0;
}
.distance {
  display: flex; align-items: center;
  font-size: 22rpx; color: #999999;
}
.dist-icon { font-size: 22rpx; margin-right: 4rpx; }
.status {
  font-size: 24rpx; color: #ffffff;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}
.status--open { background: #1FBAA6; }
.status--closed { background: #E69D87; }

/* ============ 空 / 加载 ============ */
.empty {
  padding: 120rpx 0;
  display: flex; flex-direction: column; align-items: center;
}
.empty-emoji { font-size: 120rpx; margin-bottom: 20rpx; opacity: 0.5; }
.empty-text { font-size: 26rpx; color: #999999; }

.loading {
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx 0;
  color: #999999; font-size: 24rpx;
}
.loading-spinner {
  width: 24rpx; height: 24rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #1890FF;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ============ 封面颜色 ============ */
.cover-0 { background: linear-gradient(135deg, #4A90E2, #357ABD); }
.cover-1 { background: linear-gradient(135deg, #FF6B6B, #C44569); }
.cover-2 { background: linear-gradient(135deg, #5B8DEF, #3D5AFE); }
.cover-3 { background: linear-gradient(135deg, #FFA726, #FB8C00); }
.cover-4 { background: linear-gradient(135deg, #26C6DA, #00838F); }
.cover-5 { background: linear-gradient(135deg, #66BB6A, #2E7D32); }
