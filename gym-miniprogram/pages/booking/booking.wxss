/* pages/booking/booking.wxss */

.booking-page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; padding-bottom: 40rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

/* ============ banner ============ */
.banner {
  margin: 24rpx 24rpx 0;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #3F3358, #5B4880);
  border-radius: 20rpx;
  display: flex; align-items: center;
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(63,51,88,0.25);
}
.banner-icon {
  width: 88rpx; height: 88rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; margin-right: 24rpx; flex-shrink: 0;
}
.banner-text { flex: 1; min-width: 0; }
.banner-title { font-size: 32rpx; font-weight: 700; margin-bottom: 8rpx; }
.banner-sub { font-size: 22rpx; opacity: 0.85; }
.banner-tag {
  padding: 6rpx 16rpx; background: rgba(255,255,255,0.2);
  border-radius: 16rpx; font-size: 20rpx; font-weight: 600;
  letter-spacing: 2rpx; flex-shrink: 0;
}

/* ============ tabs ============ */
.tabs {
  display: flex;
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 12rpx;
}
.tab {
  flex: 1;
  height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx;
  color: #999999;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  position: relative;
}
.tab--active {
  color: #1a1a1a;
  font-weight: 600;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.tab--active::after {
  content: '';
  position: absolute;
  bottom: 8rpx; left: 50%;
  transform: translateX(-50%);
  width: 60rpx; height: 6rpx;
  background: #1890FF;
  border-radius: 3rpx;
}

/* ============ block 通用 ============ */
.block {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.list-block { padding-bottom: 32rpx; }
.block-title {
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  position: relative;
}
.block-title::before {
  content: '';
  position: absolute; left: 0; top: 8rpx; bottom: 8rpx;
  width: 6rpx; background: #1890FF; border-radius: 3rpx;
}

/* ============ 场馆选择 ============ */
.venue-picker {
  display: flex; align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F8F8FB;
  border-radius: 12rpx;
}
.venue-icon { font-size: 28rpx; color: #1890FF; margin-right: 12rpx; }
.venue-name { flex: 1; font-size: 28rpx; color: #1a1a1a; font-weight: 500; }
.venue-arrow { font-size: 32rpx; color: #999999; margin-left: 8rpx; }

/* ============ 日期条 ============ */
.date-strip {
  white-space: nowrap;
  padding: 0 0 4rpx;
}
.date-item {
  display: inline-flex; flex-direction: column; align-items: center;
  min-width: 110rpx;
  padding: 16rpx 8rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  background: #F8F8FB;
  vertical-align: top;
}
.date-week { font-size: 24rpx; color: #888888; margin-bottom: 8rpx; }
.date-day { font-size: 36rpx; color: #1a1a1a; font-weight: 600; }
.date-item--active {
  background: #1a1a1a;
}
.date-item--active .date-week { color: rgba(255,255,255,0.7); }
.date-item--active .date-day { color: #ffffff; }

/* ============ 团课列表 ============ */
.group-list { }
.group-card {
  display: flex; align-items: stretch;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}
.group-card:last-child { border-bottom: none; }

.group-cover {
  width: 140rpx; height: 140rpx;
  border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  position: relative;
}
.group-emoji { font-size: 70rpx; filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.15)); }
.cover-0-4 {
  position: absolute; top: 8rpx; right: 8rpx;
  background: rgba(0,0,0,0.5); color: #ffffff;
  font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 8rpx;
}

.group-body { flex: 1; padding: 0 20rpx; min-width: 0; }
.group-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 6rpx; }
.group-meta {
  display: flex; align-items: center;
  font-size: 22rpx; color: #888888; margin-bottom: 6rpx;
}
.meta-time { margin-right: 16rpx; }
.group-min { font-size: 22rpx; color: #999999; margin-bottom: 10rpx; }
.group-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag {
  font-size: 20rpx; color: #666666;
  background: #f5f5f5;
  padding: 4rpx 14rpx; border-radius: 12rpx;
}

.group-right {
  width: 130rpx; flex-shrink: 0;
  display: flex; flex-direction: column; align-items: flex-end;
  justify-content: center;
}
.count { font-size: 22rpx; color: #999999; margin-bottom: 8rpx; }
.status {
  font-size: 22rpx; font-weight: 700; color: #ffffff;
  padding: 6rpx 18rpx; border-radius: 6rpx;
  display: flex; align-items: center; gap: 4rpx;
}
.status--full { background: #E94B4B; }
.status--available { background: #FFB84D; }
.status--waitlist { background: #E94B4B; }
.list-icon { font-size: 24rpx; }
.empty-status { font-size: 20rpx; color: #999999; margin-top: 4rpx; }

/* ============ 私教网格 ============ */
.private-grid {
  display: flex; flex-wrap: wrap;
  gap: 20rpx 2%;
}
.private-card {
  width: 49%;
  background: #F8F8FB;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex; flex-direction: column;
}
.private-cover {
  width: 100%; height: 200rpx;
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
}
.private-emoji { font-size: 90rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15)); }
.private-name {
  font-size: 26rpx; font-weight: 500; color: #1a1a1a;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.private-coach { font-size: 22rpx; color: #999999; margin-top: 4rpx; margin-bottom: 16rpx; }
.private-bottom { display: flex; align-items: center; justify-content: space-between; }
.private-price .price-num { font-size: 30rpx; color: #1890FF; font-weight: 700; }
.private-price .price-symbol { font-size: 22rpx; color: #1890FF; font-weight: 600; }
.private-price .price-unit { font-size: 20rpx; color: #999999; margin-left: 4rpx; }
.private-btn {
  font-size: 22rpx; color: #ffffff;
  background: #FFB84D;
  padding: 8rpx 18rpx; border-radius: 16rpx;
}
.private-btn--full { background: #E94B4B; }

/* ============ 加载 / 空 ============ */
.loading {
  text-align: center; padding: 32rpx 0;
  color: #999999; font-size: 24rpx;
  display: flex; align-items: center; justify-content: center;
}
.loading-spinner {
  width: 24rpx; height: 24rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #1890FF;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}
.empty {
  padding: 60rpx 0;
  text-align: center; color: #999999; font-size: 24rpx;
}
.empty-emoji { font-size: 80rpx; margin-bottom: 16rpx; opacity: 0.5; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ============ 场馆选择弹层 ============ */
.picker-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  display: flex; align-items: flex-end;
}
.picker-panel {
  width: 100%;
  background: #ffffff;
  border-top-left-radius: 24rpx; border-top-right-radius: 24rpx;
  padding: 32rpx 24rpx 60rpx;
  max-height: 70vh;
  overflow-y: auto;
}
.picker-title {
  font-size: 32rpx; font-weight: 600; color: #1a1a1a;
  text-align: center; margin-bottom: 24rpx;
}
.picker-item {
  display: flex; align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.picker-item:last-child { border-bottom: none; }
.picker-item--active { background: #F0F8FF; border-radius: 12rpx; }
.picker-name { font-size: 28rpx; font-weight: 500; color: #1a1a1a; margin-right: 12rpx; }
.picker-addr { font-size: 22rpx; color: #999999; flex: 1; }
.picker-check { font-size: 32rpx; color: #1890FF; font-weight: 700; }

/* ============ 封面颜色 ============ */
.cover-0 { background: linear-gradient(135deg, #4A90E2, #357ABD); }
.cover-1 { background: linear-gradient(135deg, #FF6B6B, #C44569); }
.cover-2 { background: linear-gradient(135deg, #5B8DEF, #3D5AFE); }
.cover-3 { background: linear-gradient(135deg, #FFA726, #FB8C00); }
.cover-4 { background: linear-gradient(135deg, #26C6DA, #00838F); }
.cover-5 { background: linear-gradient(135deg, #66BB6A, #2E7D32); }
.cover-6 { background: linear-gradient(135deg, #AB47BC, #6A1B9A); }
.cover-7 { background: linear-gradient(135deg, #EC407A, #C2185B); }
