/* pages/private-booking-confirm/private-booking-confirm.wxss */

.confirm-page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; padding-bottom: 140rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

.scroll { height: calc(100vh - 88rpx); }

/* ============ 通用 block ============ */
.block {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx 28rpx 32rpx;
}
.block-title {
  display: flex; align-items: center;
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  position: relative;
}
.block-title .bar {
  position: absolute; left: 0; top: 8rpx; bottom: 8rpx;
  width: 6rpx; background: #1890FF; border-radius: 3rpx;
}
.block-title .bar--green { background: #1890FF; }

/* ============ 信息表格 ============ */
.info-table {
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}
.row {
  display: flex; align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #e8e8e8;
}
.row:last-child { border-bottom: none; }
.row-key { width: 160rpx; color: #666666; font-size: 28rpx; }
.row-val { flex: 1; color: #1a1a1a; font-size: 28rpx; }

/* ============ 课时选择 ============ */
.pkg-row {
  display: flex; align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}
.pkg-key { flex: 0 0 200rpx; font-size: 28rpx; color: #1a1a1a; }
.req { color: #FF4D4F; margin-right: 4rpx; }
.pkg-options { display: flex; gap: 16rpx; flex: 1; }
.pkg-opt {
  padding: 14rpx 28rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx; color: #555555;
  background: #ffffff;
}
.pkg-opt--active {
  background: #1890FF; color: #ffffff;
  border-color: #1890FF;
  font-weight: 600;
}

/* ============ 备注 ============ */
.remark {
  width: 100%; min-height: 140rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx; color: #1a1a1a;
  box-sizing: border-box;
}

/* ============ 日期条 ============ */
.date-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  overflow-x: auto;
}
.date-pill {
  display: flex; flex-direction: column; align-items: center;
  min-width: 100rpx;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: #F8F8FB;
  flex-shrink: 0;
}
.date-pill--active {
  background: #1a1a1a;
}
.date-pill--active .date-pill-week { color: rgba(255,255,255,0.7); }
.date-pill--active .date-pill-day { color: #ffffff; }
.date-pill-week { font-size: 22rpx; color: #888888; margin-bottom: 8rpx; }
.date-pill-day { font-size: 32rpx; color: #1a1a1a; font-weight: 600; }

/* ============ 时段网格 ============ */
.slot-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}
.slot {
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  background: #ffffff;
}
.slot-time { font-size: 28rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 8rpx; }
.slot-status { font-size: 22rpx; }
.slot--ok .slot-status { color: #52C41A; }
.slot--off {
  background: #F5F5F5; border-color: #F5F5F5;
}
.slot--off .slot-time { color: #bbbbbb; }
.slot--off .slot-status { color: #bbbbbb; }
.slot--selected {
  background: #1890FF; border-color: #1890FF;
}
.slot--selected .slot-time { color: #ffffff; }
.slot--selected .slot-status { color: #ffffff; }

/* ============ 支付方式 ============ */
.pay-item {
  display: flex; align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.pay-item:last-child { border-bottom: none; }
.pay-radio {
  width: 36rpx; height: 36rpx;
  border: 4rpx solid #cccccc; border-radius: 50%;
  margin-right: 24rpx; flex-shrink: 0;
  background: #ffffff; position: relative;
  box-sizing: border-box;
}
.pay-radio--checked { border-color: #1890FF; background: #1890FF; }
.pay-radio--checked::after {
  content: ''; position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx; height: 16rpx;
  background: #ffffff; border-radius: 50%;
}
.pay-emoji { font-size: 36rpx; margin-right: 16rpx; }
.pay-name { flex: 1; font-size: 30rpx; color: #1a1a1a; }
.pay-arrow { font-size: 36rpx; color: #c0c0c0; }

/* ============ 会员卡选择列表 ============ */
.card-list { margin-top: 16rpx; }
.card-empty {
  padding: 32rpx 24rpx;
  text-align: center; font-size: 26rpx; color: #999999;
  background: #F8F8FB; border-radius: 8rpx;
}
.card-buy { color: #1890FF; margin-left: 8rpx; }

.card-row {
  display: flex; align-items: center;
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #F8F8FB;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
}
.card-row--checked { background: #E6F4FF; border-color: #1890FF; }
.card-row-icon {
  width: 72rpx; height: 72rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 20rpx;
}
.card-icon--orange { background: linear-gradient(135deg, #FF9A56, #FF7A2C); }
.card-icon--teal { background: linear-gradient(135deg, #4FD1C5, #319795); }
.card-icon--purple { background: linear-gradient(135deg, #6B8AFD, #8E6BFD); }
.card-icon-text { color: #ffffff; font-size: 30rpx; font-weight: 700; }
.card-row-body { flex: 1; min-width: 0; }
.card-row-name { font-size: 28rpx; color: #1a1a1a; font-weight: 500; margin-bottom: 4rpx; }
.card-row-info { font-size: 24rpx; color: #888888; }
.card-row-value { color: #FF4D4F; font-weight: 600; margin-right: 8rpx; }
.card-row-unit { color: #888888; }
.card-row-check {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  border: 2rpx solid #cccccc; flex-shrink: 0;
  background: #ffffff; position: relative; box-sizing: border-box;
}
.card-row-check--on { border-color: #1890FF; background: #1890FF; }
.card-row-check--on::after {
  content: '✓'; position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  color: #ffffff; font-size: 22rpx; font-weight: 700;
}

/* ============ 温馨提示 ============ */
.tips { font-size: 26rpx; color: #555555; line-height: 1.9; }

/* ============ 提交条 ============ */
.submit-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  height: 120rpx; background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex; align-items: center;
  padding: 0 16rpx;
  z-index: 50;
}
.submit-price {
  flex: 0 0 220rpx;
  display: flex; align-items: baseline;
  padding: 0 8rpx;
}
.submit-symbol { font-size: 26rpx; color: #FF4D4F; font-weight: 600; }
.submit-num { font-size: 40rpx; color: #FF4D4F; font-weight: 700; margin: 0 4rpx; }
.submit-unit { font-size: 22rpx; color: #888888; }
.submit-btn {
  flex: 1; height: 88rpx; line-height: 88rpx;
  background: #1890FF; color: #ffffff;
  text-align: center; font-size: 32rpx; font-weight: 600;
  border-radius: 44rpx; letter-spacing: 2rpx;
}
.submit-btn--disabled { background: #cccccc; }

.bottom-spacer { height: 60rpx; }

/* ============ 确认弹层 ============ */
.modal-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.modal-box {
  width: 560rpx; background: #ffffff;
  border-radius: 16rpx; overflow: hidden;
}
.modal-text {
  font-size: 30rpx; color: #1a1a1a;
  text-align: center; padding: 60rpx 40rpx 40rpx; font-weight: 500;
}
.modal-btns {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}
.modal-btn {
  flex: 1; height: 100rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx;
  border-right: 1rpx solid #f0f0f0;
}
.modal-btn:last-child { border-right: none; }
.modal-btn--cancel { color: #666666; }
.modal-btn--ok { color: #1890FF; font-weight: 500; }
