/* pages/index/index.wxss */

.home {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* ============ Banner ============ */
.banner {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner-slide {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: background 0.4s ease;
}

.banner-emoji {
  font-size: 140rpx;
  line-height: 1;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.15));
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.banner-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 2rpx;
}

.banner-dots {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
}

.dot--active {
  background: #ffffff;
}

/* ============ 公告 ============ */
.notice {
  margin: 20rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.notice-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FF6B9D, #C4476B);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #444444;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ============ Section 通用 ============ */
.section {
  margin: 24rpx 0 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-bar {
  display: inline-block;
  width: 6rpx;
  height: 30rpx;
  background: #1890FF;
  border-radius: 3rpx;
  margin-right: 14rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

/* ============ 推荐私教 / 推荐课程 横滑大卡 ============ */
.card-row {
  white-space: nowrap;
  padding: 0 24rpx 8rpx;
}

.big-card {
  display: inline-block;
  width: 540rpx;
  margin-right: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  vertical-align: top;
}

.big-card-cover {
  position: relative;
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.big-card-emoji {
  font-size: 120rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.hot-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #FF4D4F;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 6rpx rgba(255,77,79,0.4);
}

.big-card-body {
  padding: 20rpx 24rpx 24rpx;
}

.big-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.big-card-tags {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.big-card-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #1890FF;
  font-weight: 600;
}

.price-num {
  font-size: 40rpx;
  color: #1890FF;
  font-weight: 700;
  margin: 0 4rpx;
}

.price-unit {
  font-size: 22rpx;
  color: #999999;
  margin-left: 4rpx;
}

/* ============ 周边商品 双列网格 ============ */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 24rpx 2%;
}

.product-card {
  width: 49%;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 8rpx;
}

.product-cover {
  width: 100%;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-emoji {
  font-size: 110rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.product-name {
  padding: 16rpx 20rpx 0;
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx 20rpx;
}

.product-price .price-num {
  font-size: 32rpx;
}

.cart-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f0f8ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

/* ============ 颜色变体（封面渐变） ============ */
.cover-0 { background: linear-gradient(135deg, #4A90E2, #357ABD); }
.cover-1 { background: linear-gradient(135deg, #FF6B6B, #C44569); }
.cover-2 { background: linear-gradient(135deg, #5B8DEF, #3D5AFE); }
.cover-3 { background: linear-gradient(135deg, #FFA726, #FB8C00); }
.cover-4 { background: linear-gradient(135deg, #26C6DA, #00838F); }
.cover-5 { background: linear-gradient(135deg, #66BB6A, #2E7D32); }
.cover-6 { background: linear-gradient(135deg, #AB47BC, #6A1B9A); }
.cover-7 { background: linear-gradient(135deg, #EC407A, #C2185B); }

/* ============ 加载 ============ */
.loading {
  text-align: center;
  padding: 40rpx 0 20rpx;
  color: #999999;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #1890FF;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
