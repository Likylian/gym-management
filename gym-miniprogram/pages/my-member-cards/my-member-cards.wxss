/* pages/my-member-cards/my-member-cards.wxss */

.page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

/* ============ 卡片列表 ============ */
.list { padding: 24rpx; }

.mcard {
  display: flex; align-items: stretch;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
}

.mcard-left {
  width: 180rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #ffffff;
  padding: 32rpx 0;
  position: relative;
}
.mcard-left::after {
  content: ''; position: absolute;
  right: 0; top: 0; bottom: 0; width: 4rpx;
  background: repeating-linear-gradient(
    to bottom, transparent 0, transparent 8rpx, #ffffff 8rpx, #ffffff 12rpx
  );
}
.mcard--orange .mcard-left { background: linear-gradient(135deg, #FF9A56, #FF7A2C); }
.mcard--purple .mcard-left { background: linear-gradient(135deg, #6B8AFD, #8E6BFD); }
.mcard--teal .mcard-left { background: linear-gradient(135deg, #4FD1C5, #319795); }
.mcard--red .mcard-left { background: linear-gradient(135deg, #F77062, #C44569); }
.mcard--blue .mcard-left { background: linear-gradient(135deg, #4A90E2, #357ABD); }

.mcard-left-num { font-size: 56rpx; font-weight: 700; line-height: 1; }
.mcard-left-sub { font-size: 22rpx; opacity: 0.9; margin-top: 12rpx; }

.mcard-mid {
  flex: 1;
  padding: 24rpx 28rpx;
  display: flex; flex-direction: column; justify-content: center;
}
.mcard-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 12rpx; }
.mcard-row { font-size: 24rpx; color: #888888; line-height: 1.7; }
.mcard-val { color: #555555; }

.mcard-right {
  width: 140rpx;
  display: flex; align-items: center; justify-content: center;
  border-left: 1rpx dashed #e0e0e0;
  flex-shrink: 0;
}
.mcard-action {
  font-size: 28rpx; color: #1a1a1a;
  padding: 16rpx 28rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 28rpx;
}

/* ============ 加载/空 ============ */
.loading { text-align: center; padding: 60rpx 0; color: #999999; font-size: 24rpx; }
.spinner {
  width: 24rpx; height: 24rpx; border: 3rpx solid #e0e0e0;
  border-top-color: #1890FF; border-radius: 50%;
  margin: 0 auto 12rpx; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.empty {
  text-align: center; padding: 120rpx 0; color: #999999;
  display: flex; flex-direction: column; align-items: center;
}
.empty-emoji { font-size: 80rpx; margin-bottom: 16rpx; opacity: 0.5; }
.empty-go {
  margin-top: 24rpx; padding: 16rpx 40rpx;
  background: #1890FF; color: #ffffff;
  border-radius: 32rpx; font-size: 26rpx;
}

/* ============ 底部购买入口 ============ */
.footer-action {
  display: flex; align-items: center; justify-content: center;
  margin-top: 16rpx;
  padding: 28rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.footer-icon {
  width: 48rpx; height: 48rpx; line-height: 44rpx;
  background: #1890FF; color: #ffffff;
  border-radius: 50%;
  text-align: center;
  font-size: 36rpx; font-weight: 300;
  margin-right: 16rpx;
}
.footer-text { font-size: 30rpx; color: #1a1a1a; font-weight: 500; }
