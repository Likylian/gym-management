/* pages/group-detail/group-detail.wxss */

.detail-page { min-height: 100vh; background: #F5F5F5; padding-bottom: 140rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx;
  background: rgba(0,0,0,0.4);
  display: flex; align-items: center;
  z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx;
  margin-right: 88rpx;  /* 抵消左侧返回键的占位 */
}
.navbar-right { width: 88rpx; }

/* ============ 顶部 cover ============ */
.cover {
  width: 100%; height: 400rpx;
  display: flex; align-items: center; justify-content: center;
}
.cover-emoji { font-size: 180rpx; filter: drop-shadow(0 4rpx 16rpx rgba(0,0,0,0.2)); }

/* ============ 课程头信息 ============ */
.course-head {
  background: #ffffff;
  padding: 24rpx 28rpx;
}
.course-row1 { display: flex; align-items: center; margin-bottom: 16rpx; }
.course-tag {
  font-size: 22rpx; color: #ffffff; background: #FFB84D;
  padding: 4rpx 14rpx; border-radius: 6rpx;
  margin-right: 16rpx; font-weight: 600;
  flex-shrink: 0;
}
.course-name {
  font-size: 32rpx; font-weight: 700; color: #1a1a1a;
  flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.course-row2 {
  display: flex; align-items: baseline; flex-wrap: wrap;
}
.price-symbol { font-size: 28rpx; color: #1890FF; font-weight: 600; }
.price-num { font-size: 44rpx; color: #1890FF; font-weight: 700; margin: 0 4rpx; }
.price-unit { font-size: 24rpx; color: #1890FF; margin-right: 16rpx; }
.price-origin {
  font-size: 24rpx; color: #999999; text-decoration: line-through;
  margin-right: 16rpx;
}
.course-tag-right {
  margin-left: auto;
  font-size: 24rpx; color: #ffffff;
  padding: 4rpx 18rpx; border-radius: 20rpx;
  font-weight: 500;
}

/* ============ 3 tab ============ */
.tabbar {
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}
.tab {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #888888;
  position: relative;
}
.tab--active { color: #1a1a1a; font-weight: 600; }
.tab--active::after {
  content: '';
  position: absolute; bottom: 12rpx; left: 50%;
  transform: translateX(-50%);
  width: 60rpx; height: 6rpx; background: #1a1a1a;
  border-radius: 3rpx;
}

/* ============ block 通用 ============ */
.block {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.block-title {
  display: flex; align-items: center;
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  position: relative;
}
.block-title .bar {
  display: inline-block;
  width: 6rpx; height: 28rpx; background: #1890FF;
  border-radius: 3rpx; margin-right: 12rpx;
}
.block-body { font-size: 28rpx; color: #444444; line-height: 1.7; }

/* ============ 教练卡 ============ */
.coach-card {
  display: flex; align-items: center;
}
.coach-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff;
  margin-right: 24rpx; flex-shrink: 0;
}
.coach-info { flex: 1; }
.coach-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 8rpx; }
.coach-title { font-size: 24rpx; color: #888888; line-height: 1.6; }

/* ============ 课程章节（差异化内容） ============ */
.course-section { margin-bottom: 28rpx; }
.course-section:last-child { margin-bottom: 0; }
.section-title {
  font-size: 28rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 12rpx;
}
.section-content {
  font-size: 26rpx; color: #555555; line-height: 1.8;
}
.section-img {
  width: 100%; height: 320rpx;
  border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  margin-top: 16rpx;
}
.section-img-emoji { font-size: 120rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15)); }

/* ============ 会员卡 ============ */
.mcard {
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
  position: relative;
}
.mcard:last-child { margin-bottom: 0; }
.mcard--purple { background: linear-gradient(135deg, #6B8AFD, #8E6BFD); }
.mcard--red { background: linear-gradient(135deg, #F77062, #C44569); }
.mcard--teal { background: linear-gradient(135deg, #4FD1C5, #319795); }

.mcard-name { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; letter-spacing: 1rpx; }
.mcard-row { font-size: 24rpx; opacity: 0.95; line-height: 1.8; }
.mcard-val { font-weight: 600; }
.mcard-btn {
  position: absolute; right: 28rpx; top: 50%; transform: translateY(-50%);
  background: rgba(255,255,255,0.25);
  font-size: 26rpx; color: #ffffff;
  padding: 12rpx 28rpx; border-radius: 30rpx;
  font-weight: 500;
}

/* ============ 评论 ============ */
.review { padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review:last-child { border-bottom: none; }
.review-head { display: flex; align-items: center; margin-bottom: 12rpx; }
.review-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #ffffff;
  margin-right: 16rpx; flex-shrink: 0;
}
.review-name { font-size: 26rpx; font-weight: 500; color: #1a1a1a; }
.review-time { font-size: 22rpx; color: #999999; }
.review-text { font-size: 26rpx; color: #444444; line-height: 1.6; margin-bottom: 12rpx; }
.review-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.tag-orange {
  font-size: 22rpx; color: #FF8800;
  background: #FFF4E5;
  padding: 4rpx 14rpx; border-radius: 12rpx;
}
.review-imgs { display: flex; gap: 12rpx; }
.review-img {
  width: 130rpx; height: 130rpx;
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.review-img-emoji { font-size: 60rpx; filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.1)); }

/* ============ 底部操作条 ============ */
.bottom-spacer { height: 60rpx; }
.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  height: 120rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex; align-items: center;
  padding: 0 16rpx;
  z-index: 50;
}
.action-side {
  flex: 0 0 120rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.action-emoji { font-size: 36rpx; color: #555555; line-height: 1; margin-bottom: 6rpx; }
.action-label { font-size: 22rpx; color: #555555; }
.action-main {
  flex: 1; margin-left: 16rpx;
  height: 88rpx; line-height: 88rpx;
  background: #1890FF; color: #ffffff;
  text-align: center;
  font-size: 32rpx; font-weight: 600; letter-spacing: 2rpx;
  border-radius: 44rpx;
}

/* ============ 确认弹层 ============ */
.modal-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.modal-box {
  width: 560rpx; background: #ffffff;
  border-radius: 16rpx; overflow: hidden;
}
.modal-text {
  font-size: 30rpx; color: #1a1a1a;
  text-align: center;
  padding: 60rpx 40rpx 40rpx;
  font-weight: 500;
}
.modal-btns {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}
.modal-btn {
  flex: 1; height: 100rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx;
  border-right: 1rpx solid #f0f0f0;
}
.modal-btn:last-child { border-right: none; }
.modal-btn--cancel { color: #666666; }
.modal-btn--ok { color: #1890FF; font-weight: 500; }

/* ============ 加载 ============ */
.loading-state {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #999999; font-size: 26rpx;
}
.loading-spinner {
  width: 32rpx; height: 32rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1890FF;
  border-radius: 50%;
  margin-bottom: 16rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ============ 封面颜色 ============ */
.cover-0 { background: linear-gradient(135deg, #4A90E2, #357ABD); }
.cover-1 { background: linear-gradient(135deg, #FF6B6B, #C44569); }
.cover-2 { background: linear-gradient(135deg, #5B8DEF, #3D5AFE); }
.cover-3 { background: linear-gradient(135deg, #FFA726, #FB8C00); }
.cover-4 { background: linear-gradient(135deg, #26C6DA, #00838F); }
.cover-5 { background: linear-gradient(135deg, #66BB6A, #2E7D32); }
.cover-6 { background: linear-gradient(135deg, #AB47BC, #6A1B9A); }
.cover-7 { background: linear-gradient(135deg, #EC407A, #C2185B); }
