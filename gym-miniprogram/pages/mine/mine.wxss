/* pages/mine/mine.wxss */
.mine-page { min-height: 100vh; background: #F5F5F5; padding-bottom: 80rpx; }

/* ---------- 用户卡片 ---------- */
.user-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #3F3358, #564A70);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  position: relative;
}
.avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(255,255,255,0.22);
  display: flex; align-items: center; justify-content: center;
  font-size: 38rpx; color: #ffffff;
}
.user-info { flex: 1; margin-left: 24rpx; }
.nickname { font-size: 36rpx; font-weight: 600; color: #ffffff; margin-bottom: 8rpx; }
.phone { font-size: 26rpx; color: rgba(255,255,255,0.75); }
.badge {
  padding: 6rpx 18rpx; background: rgba(255,255,255,0.2);
  border-radius: 20rpx; font-size: 22rpx; color: #ffffff;
}

/* ---------- 菜单 ---------- */
.menu {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex; align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { width: 52rpx; font-size: 34rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #333333; margin-left: 12rpx; }
.menu-extra { font-size: 26rpx; color: #1890FF; margin-right: 12rpx; }
.menu-arrow { font-size: 32rpx; color: #c0c0c0; }

/* ---------- 退出登录 ---------- */
.logout-area {
  margin: 48rpx 24rpx;
  display: flex; flex-direction: column; align-items: center;
}
.db-status {
  display: flex; align-items: center;
  margin-bottom: 32rpx;
}
.db-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #c0c0c0; margin-right: 10rpx;
}
.db-dot--ok { background: #52C41A; }
.db-dot--err { background: #FF4D4F; }
.db-text { font-size: 24rpx; color: #888888; }

.logout-btn {
  width: 80%;
  height: 80rpx; line-height: 80rpx;
  background: #ffffff;
  color: #FF4D4F;
  font-size: 30rpx;
  border: 2rpx solid #ffccc7;
  border-radius: 40rpx;
  text-align: center;
}
.logout-hint {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #b0b0b0;
  text-align: center;
}

/* ---------- 未登录 ---------- */
.no-login {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 0 60rpx;
}
.nl-emoji { font-size: 160rpx; margin-bottom: 24rpx; }
.nl-title { font-size: 38rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 12rpx; }
.nl-sub { font-size: 28rpx; color: #888888; margin-bottom: 48rpx; }
.nl-btn {
  width: 320rpx; height: 80rpx; line-height: 80rpx;
  background: #3F3358; color: #ffffff; font-size: 30rpx;
  border-radius: 40rpx; text-align: center;
}
