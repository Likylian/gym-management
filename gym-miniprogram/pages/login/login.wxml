<!-- pages/login/login.wxml -->
<view class="login-page">

  <!-- Logo + 标题 -->
  <view class="header">
    <view class="logo">
      <!-- 后续可替换为实际 logo 图片：<image src="/images/logo.png" /> -->
      <text class="logo-emoji">💪</text>
    </view>
    <text class="title">健身预约系统</text>
  </view>

  <!-- 表单 -->
  <view class="form">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="ph"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">动态码</text>
      <input
        class="form-input code-input"
        type="number"
        maxlength="6"
        placeholder="请输入六位手机动态码"
        placeholder-class="ph"
        value="{{code}}"
        bindinput="onCodeInput"
      />
      <view
        class="send-code {{countdown > 0 ? 'disabled' : ''}}"
        bindtap="onSendCode"
      >{{countdown > 0 ? countdown + 's 后重发' : '获取动态码'}}</view>
    </view>
  </view>

  <text class="hint">未注册的手机号，系统将自动为您创建帐号</text>

  <!-- 协议勾选 -->
  <view class="agreement" bindtap="toggleAgree">
    <view class="checkbox {{agreed ? 'checkbox--checked' : ''}}">
      <view wx:if="{{agreed}}" class="checkbox-tick"></view>
    </view>
    <text class="agreement-text">
      勾选同意<text class="link" catchtap="goAgreement">《用户协议》</text>和<text class="link" catchtap="goPrivacy">《隐私政策》</text>
    </text>
  </view>

  <!-- 登录按钮 -->
  <button
    class="login-btn {{loading ? 'login-btn--loading' : ''}}"
    bindtap="onLogin"
    disabled="{{loading}}"
  >{{loading ? '登录中...' : '登录'}}</button>
</view>
