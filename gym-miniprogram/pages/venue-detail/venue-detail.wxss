/* pages/venue-detail/venue-detail.wxss */

.detail-page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx;
  background: #3F3358;
  display: flex; align-items: center;
  z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx;
  margin-right: 88rpx;  /* 抵消左侧返回键的占位 */
}
.navbar-right { width: 88rpx; }

/* ============ 顶部图集 ============ */
.gallery {
  background: #ffffff;
  padding: 24rpx 0;
}
.gallery-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}
.gallery-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center; justify-content: center;
  width: 560rpx; height: 320rpx;
  margin-right: 24rpx;
  border-radius: 16rpx;
  vertical-align: top;
}
.gallery-emoji { font-size: 130rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15)); }
.gallery-label { margin-top: 12rpx; font-size: 26rpx; color: #ffffff; font-weight: 500; letter-spacing: 1rpx; }

/* ============ 通用 block ============ */
.block {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.block-title {
  display: flex; align-items: center;
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.block-title .bar {
  display: inline-block;
  width: 6rpx; height: 28rpx;
  background: #1890FF;
  border-radius: 3rpx;
  margin-right: 12rpx;
}
.block-body { font-size: 28rpx; color: #444444; line-height: 1.7; }
.paragraph { margin-bottom: 20rpx; }

/* 大图占位 */
.big-img {
  width: 100%; height: 360rpx;
  border-radius: 16rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  margin: 20rpx 0;
}
.big-emoji { font-size: 140rpx; filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.2)); }
.big-label { margin-top: 16rpx; font-size: 26rpx; color: #ffffff; letter-spacing: 2rpx; }

/* ============ 设施配套 ============ */
.facilities {
  display: flex; flex-wrap: wrap;
  gap: 16rpx 4%;
}
.facility {
  width: 22%;
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 0;
  background: #F8F8FB;
  border-radius: 12rpx;
}
.facility-emoji { font-size: 44rpx; margin-bottom: 8rpx; }
.facility-label { font-size: 22rpx; color: #555555; }

/* ============ 教练 ============ */
.coach-list {
  display: flex; flex-wrap: wrap;
  gap: 16rpx;
}
.coach-card {
  width: 30%;
  background: #F8F8FB;
  border-radius: 12rpx;
  padding: 20rpx 0;
  display: flex; flex-direction: column; align-items: center;
}
.coach-avatar {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; color: #ffffff;
  margin-bottom: 12rpx;
}
.coach-name { font-size: 26rpx; font-weight: 500; color: #1a1a1a; }
.coach-tag { font-size: 22rpx; color: #888888; margin-top: 4rpx; }

/* ============ 联系信息 ============ */
.contact-row {
  display: flex; align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx; color: #444444;
}
.contact-icon { width: 48rpx; font-size: 30rpx; }
.contact-text { flex: 1; }

.rating-row {
  display: flex; align-items: center;
  padding: 16rpx 0 0;
  margin-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}
.stars { display: flex; }
.star { font-size: 36rpx; color: #FFC53D; margin-right: 6rpx; }
.rating-text { font-size: 26rpx; color: #FF6B35; font-weight: 600; margin-left: 12rpx; }
.review-count { font-size: 22rpx; color: #999999; margin-left: 6rpx; }

/* ============ 底部留白 ============ */
.bottom-spacer { height: 140rpx; }

/* ============ 悬浮预约按钮 ============ */
.fab {
  position: fixed;
  right: 32rpx; bottom: 48rpx;
  height: 80rpx; line-height: 80rpx;
  padding: 0 36rpx;
  background: #1890FF;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(24,144,255,0.4);
  z-index: 50;
}

/* ============ 加载 ============ */
.loading-state {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: #999999; font-size: 26rpx;
}
.loading-spinner {
  width: 32rpx; height: 32rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1890FF;
  border-radius: 50%;
  margin-bottom: 16rpx;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ============ 颜色变体 ============ */
.cover-0 { background: linear-gradient(135deg, #4A90E2, #357ABD); }
.cover-1 { background: linear-gradient(135deg, #FF6B6B, #C44569); }
.cover-2 { background: linear-gradient(135deg, #5B8DEF, #3D5AFE); }
.cover-3 { background: linear-gradient(135deg, #FFA726, #FB8C00); }
.cover-4 { background: linear-gradient(135deg, #26C6DA, #00838F); }
.cover-5 { background: linear-gradient(135deg, #66BB6A, #2E7D32); }
.cover-6 { background: linear-gradient(135deg, #AB47BC, #6A1B9A); }
.cover-7 { background: linear-gradient(135deg, #EC407A, #C2185B); }
