/* pages/booking-success/booking-success.wxss */

.success-page { min-height: 100vh; background: #ffffff; padding-top: 88rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

/* ============ Hero ============ */
.hero {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 0 60rpx;
}
.hero-icon {
  width: 200rpx; height: 200rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(74,144,226,0.3);
}
.hero-emoji { font-size: 110rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.2)); }
.hero-title {
  font-size: 44rpx; font-weight: 700; color: #1a1a1a;
  letter-spacing: 4rpx;
}

/* ============ 信息卡 ============ */
.info-card {
  margin: 0 60rpx;
  padding: 40rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.info-row {
  display: flex; align-items: center;
  padding: 16rpx 0;
}
.info-emoji { font-size: 32rpx; margin-right: 16rpx; }
.info-key { flex: 1; font-size: 30rpx; color: #555555; }
.info-val { font-size: 30rpx; color: #1a1a1a; }
.info-val--red { color: #FF4D4F; font-weight: 600; }
.info-divider {
  height: 1rpx; background: #f0f0f0;
}

/* ============ 操作按钮 ============ */
.action {
  padding: 60rpx 60rpx 0;
  display: flex; justify-content: center;
}
.action-btn {
  width: 320rpx; height: 80rpx; line-height: 80rpx;
  background: #ffffff;
  border: 2rpx solid #d0d0d0;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx; color: #555555;
}
