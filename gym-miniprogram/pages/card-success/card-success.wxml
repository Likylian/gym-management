<!-- pages/card-success/card-success.wxml -->
<view class="page">
  <view class="navbar">
    <view class="navbar-back" bindtap="goBack">‹</view>
    <view class="navbar-title">支付成功</view>
    <view class="navbar-right"></view>
  </view>

  <view class="hero">
    <view class="hero-icon">📅</view>
    <view class="hero-title">支付成功</view>
  </view>

  <view class="info-card">
    <view class="info-row">
      <text class="info-emoji">💳</text>
      <text class="info-key">支付方式</text>
      <text class="info-val info-val--red">{{info.payLabel}}</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <text class="info-emoji">💰</text>
      <text class="info-key">支付金额</text>
      <text class="info-val info-val--red">¥{{info.price}}</text>
    </view>
  </view>

  <view class="action">
    <view class="action-btn" bindtap="viewCards">查看卡片</view>
  </view>

  <view class="tip">
    <view class="tip-title">温馨提示：</view>
    <view class="tip-text">平台不会以订单异常、系统升级为由要求您点击任何网址链接进行退款操作。</view>
  </view>
</view>
