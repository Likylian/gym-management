/* pages/message/message.wxss */
.placeholder {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
}
.ph-emoji { font-size: 160rpx; margin-bottom: 32rpx; filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.08)); }
.ph-title { font-size: 40rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 16rpx; }
.ph-sub { font-size: 28rpx; color: #888888; margin-bottom: 40rpx; text-align: center; }
.ph-tag { font-size: 24rpx; color: #1890FF; background: #E6F4FF; padding: 8rpx 24rpx; border-radius: 24rpx; }
