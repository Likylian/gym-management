/* pages/member-cards/member-cards.wxss */

.page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

/* ============ tabs ============ */
.tabs {
  display: flex; background: #ffffff;
  padding: 0 24rpx; border-bottom: 1rpx solid #f0f0f0;
}
.tab {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #555555;
  position: relative;
}
.tab--active { color: #1a1a1a; font-weight: 600; }
.tab--active::after {
  content: ''; position: absolute; bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 60rpx; height: 6rpx; background: #1890FF; border-radius: 3rpx;
}

/* ============ card ============ */
.list { padding: 24rpx; }
.mcard {
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}
.mcard--purple { background: linear-gradient(135deg, #6B8AFD, #8E6BFD); }
.mcard--red { background: linear-gradient(135deg, #F77062, #C44569); }
.mcard--teal { background: linear-gradient(135deg, #4FD1C5, #319795); }
.mcard--blue { background: linear-gradient(135deg, #4A90E2, #357ABD); }
.mcard--orange { background: linear-gradient(135deg, #FFA726, #FB8C00); }
.mcard--green { background: linear-gradient(135deg, #66BB6A, #2E7D32); }

.mcard-top {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.mcard-name { font-size: 36rpx; font-weight: 700; letter-spacing: 1rpx; }
.mcard-type {
  font-size: 24rpx; background: rgba(255,255,255,0.25);
  padding: 4rpx 16rpx; border-radius: 16rpx;
}
.mcard-row { font-size: 24rpx; opacity: 0.95; line-height: 1.8; }
.mcard-val { font-weight: 600; }
.mcard-foot {
  display: flex; align-items: baseline;
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.3);
}
.mcard-price { font-size: 24rpx; }
.mcard-price-val { font-size: 32rpx; font-weight: 700; margin: 0 4rpx; }
.mcard-origin {
  font-size: 22rpx; opacity: 0.7;
  text-decoration: line-through; margin-left: 16rpx;
}

/* ============ 加载/空 ============ */
.loading { text-align: center; padding: 60rpx 0; color: #999999; font-size: 24rpx; }
.spinner {
  width: 24rpx; height: 24rpx; border: 3rpx solid #e0e0e0;
  border-top-color: #1890FF; border-radius: 50%;
  margin: 0 auto 12rpx; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.empty { text-align: center; padding: 120rpx 0; color: #999999; font-size: 24rpx; }
.empty-emoji { font-size: 80rpx; margin-bottom: 16rpx; }
