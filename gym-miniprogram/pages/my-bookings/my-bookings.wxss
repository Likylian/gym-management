/* pages/my-bookings/my-bookings.wxss */

.page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

/* ============ 卡片 ============ */
.list { padding: 24rpx; }
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.card-top {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20rpx;
}
.card-course { font-size: 30rpx; font-weight: 600; color: #1a1a1a; flex: 1; }
.card-status { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 12rpx; }
.status--booked { color: #1890FF; background: #E6F4FF; }
.status--done { color: #52C41A; background: #F6FFED; }
.status--canceled { color: #999999; background: #F5F5F5; }

.card-row {
  display: flex; align-items: center; padding: 10rpx 0;
  font-size: 26rpx;
}
.card-key { color: #888888; width: 90rpx; flex-shrink: 0; }
.card-val { color: #333333; }

.card-foot {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 20rpx; margin-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.card-time { font-size: 22rpx; color: #999999; }
.card-cancel {
  font-size: 24rpx; color: #FF4D4F;
  padding: 6rpx 20rpx;
  border: 2rpx solid #ffccc7;
  border-radius: 24rpx;
}

/* ============ 加载/空 ============ */
.loading { text-align: center; padding: 60rpx 0; color: #999999; font-size: 24rpx; }
.spinner {
  width: 24rpx; height: 24rpx; border: 3rpx solid #e0e0e0;
  border-top-color: #1890FF; border-radius: 50%;
  margin: 0 auto 12rpx; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.empty { text-align: center; padding: 120rpx 0; color: #999999; }
.empty-emoji { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; }
