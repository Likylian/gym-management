/* pages/booking-confirm/booking-confirm.wxss */

.confirm-page { min-height: 100vh; background: #F5F5F5; padding-top: 88rpx; padding-bottom: 140rpx; }

/* ============ navbar ============ */
.navbar {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #3F3358;
  display: flex; align-items: center; z-index: 99;
}
.navbar-back {
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #ffffff; font-weight: 300;
}
.navbar-title {
  flex: 1; text-align: center;
  font-size: 32rpx; font-weight: 600; color: #ffffff;
  letter-spacing: 2rpx; margin-right: 88rpx;
}
.navbar-right { width: 88rpx; }

.scroll { height: calc(100vh - 88rpx); }

/* ============ 通用 block ============ */
.block {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 28rpx 28rpx 32rpx;
}
.block-title {
  display: flex; align-items: center;
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  position: relative;
}
.block-title .bar {
  position: absolute; left: 0; top: 8rpx; bottom: 8rpx;
  width: 6rpx; background: #1890FF; border-radius: 3rpx;
}
.block-title .bar--green { background: #1890FF; }

/* ============ 信息表格 ============ */
.info-table {
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}
.row {
  display: flex; align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #e8e8e8;
}
.row:last-child { border-bottom: none; }
.row-key { width: 160rpx; color: #666666; font-size: 28rpx; }
.row-val { flex: 1; color: #1a1a1a; font-size: 28rpx; }

/* ============ 人数 stepper ============ */
.stepper-row {
  display: flex; align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}
.stepper-key { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.req { color: #FF4D4F; margin-right: 4rpx; }
.stepper {
  display: flex; align-items: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  overflow: hidden;
}
.stepper-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #1a1a1a; background: #f8f8f8;
}
.stepper-num {
  width: 80rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: #1a1a1a; font-weight: 600;
  border-left: 2rpx solid #e8e8e8;
  border-right: 2rpx solid #e8e8e8;
}

/* ============ 备注 ============ */
.remark {
  width: 100%; min-height: 140rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx; color: #1a1a1a;
  box-sizing: border-box;
}

/* ============ 支付方式 ============ */
.pay-list {}
.pay-item {
  display: flex; align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.pay-item:last-child { border-bottom: none; }
.pay-radio {
  width: 36rpx; height: 36rpx;
  border: 4rpx solid #cccccc;
  border-radius: 50%;
  margin-right: 24rpx; flex-shrink: 0;
  background: #ffffff;
  position: relative;
  box-sizing: border-box;
}
.pay-radio--checked {
  border-color: #1890FF;
  background: #1890FF;
}
.pay-radio--checked::after {
  content: '';
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx; height: 16rpx;
  background: #ffffff; border-radius: 50%;
}
.pay-emoji { font-size: 36rpx; margin-right: 16rpx; }
.pay-name { flex: 1; font-size: 30rpx; color: #1a1a1a; }
.pay-arrow { font-size: 36rpx; color: #c0c0c0; }

/* ============ 会员卡选择列表 ============ */
.card-list { margin-top: 16rpx; }
.card-empty {
  padding: 32rpx 24rpx;
  text-align: center; font-size: 26rpx; color: #999999;
  background: #F8F8FB; border-radius: 8rpx;
}
.card-buy { color: #1890FF; margin-left: 8rpx; }

.card-row {
  display: flex; align-items: center;
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #F8F8FB;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
}
.card-row--checked {
  background: #E6F4FF;
  border-color: #1890FF;
}
.card-row-icon {
  width: 72rpx; height: 72rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 20rpx;
}
.card-icon--orange { background: linear-gradient(135deg, #FF9A56, #FF7A2C); }
.card-icon--teal { background: linear-gradient(135deg, #4FD1C5, #319795); }
.card-icon--purple { background: linear-gradient(135deg, #6B8AFD, #8E6BFD); }
.card-icon-text { color: #ffffff; font-size: 30rpx; font-weight: 700; }
.card-row-body { flex: 1; min-width: 0; }
.card-row-name { font-size: 28rpx; color: #1a1a1a; font-weight: 500; margin-bottom: 4rpx; }
.card-row-info { font-size: 24rpx; color: #888888; }
.card-row-value { color: #FF4D4F; font-weight: 600; margin-right: 8rpx; }
.card-row-unit { color: #888888; }
.card-row-check {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  border: 2rpx solid #cccccc; flex-shrink: 0;
  background: #ffffff;
  position: relative; box-sizing: border-box;
}
.card-row-check--on { border-color: #1890FF; background: #1890FF; }
.card-row-check--on::after {
  content: '✓'; position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  color: #ffffff; font-size: 22rpx; font-weight: 700;
}

/* ============ 温馨提示 ============ */
.tips { font-size: 26rpx; color: #555555; line-height: 1.9; }

/* ============ 提交按钮 ============ */
.submit-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  height: 120rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex; align-items: center;
  padding: 0 24rpx;
  z-index: 50;
}
.submit-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: #1890FF; color: #ffffff;
  text-align: center; font-size: 32rpx; font-weight: 600;
  border-radius: 44rpx; letter-spacing: 2rpx;
}

.bottom-spacer { height: 60rpx; }
